rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get the requesting user's role
    // Returns null if staff doc doesn't exist (prevents lockouts)
    function getUserRole() {
      let doc = get(/databases/$(database)/documents/staff/$(request.auth.uid));
      return doc.exists ? doc.data.role : null;
    }

    // === STAFF COLLECTION ===
    match /staff/{userId} {

      // List: Admins only
      allow list: if request.auth != null
        && getUserRole() == 'admin';

      // Get:
      //  - Users can read their own doc
      //  - Admins can read anyone's doc
      allow get: if request.auth != null
        && (request.auth.uid == userId
            || getUserRole() == 'admin');

      // Create: Authenticated users can only create their own doc
      // Enforces role=staff, isActive=true, and required fields
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.role == 'staff'
        && request.resource.data.isActive == true
        && request.resource.data.keys().hasAll(['email', 'displayName', 'role', 'isActive', 'createdAt'])
        && request.resource.data.keys().hasOnly(['email', 'displayName', 'role', 'isActive', 'createdAt', 'age', 'sex', 'birthday', 'photoURL', 'firebaseUid']);

      // Update:
      //  - Users can update their own doc (limited fields: displayName, photoURL)
      //  - Admins can update anyone (including role changes)
      //  - Managers can update staff (not role)
      allow update: if request.auth != null
        && (
          // Own profile: limited fields only
          (request.auth.uid == userId
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['displayName', 'photoURL', 'age', 'sex', 'birthday', 'updatedAt']))
          ||
          // Admin: full access
          getUserRole() == 'admin'
          ||
          // Manager: can update staff users only, cannot change role
          (getUserRole() == 'manager'
            && resource.data.role == 'staff'
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['displayName', 'photoURL', 'isActive', 'updatedAt']))
        );

      // Delete: Admins only
      allow delete: if request.auth != null
        && getUserRole() == 'admin';
    }

    // === DENY ALL OTHER COLLECTIONS ===
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
